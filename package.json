{
  "name": "home-budget-agent",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "prepare": "husky",
    "generate:types": "python3 backend/scripts/export_openapi.py && cd frontend && pnpm generate:types"
  },
  "lint-staged": {
    "frontend/**/*.{ts,tsx}": [
      "bash -c 'cd frontend && npx eslint --no-warn-ignored --max-warnings=0 \"${@}\"' --"
    ],
    "backend/**/*.py": [
      "bash -c 'cd backend && source venv/bin/activate && ruff check \"${@}\"' --"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild"
    ]
  }
}

